      "platforms": ["all"],
      "languages": ["all"],
      "check_command": "command -v colima",
      "version_command": "colima version 2>/dev/null | head -1 | awk '{print $3}' | tr -d 'v'",
      "min_version": "0.6.0",
      "latest_check": {"method": "github_release", "package": "abiosoft/colima"},
